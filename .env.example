# Copy this file to .env and fill in your values before running.

# Flask
FLASK_SECRET_KEY=change-me-to-a-random-string
FLASK_ENV=development

# Twilio — use the Auth Token of the account that owns the Event Streams subscription.
# For master-account subscriptions covering subaccounts, use the MASTER account Auth Token.
TWILIO_AUTH_TOKEN=your_auth_token_here

# Dashboard access token (demo-grade auth — share this with viewers).
DASHBOARD_TOKEN=demo-access-token

# Database
# SQLite (zero setup, good for local demo):
DATABASE_URL=sqlite:///dev.db
# PostgreSQL (for Docker or production-like setup):
# DATABASE_URL=postgresql://dashuser:password@localhost:5432/twilio_dashboard

# Set to true to SKIP Twilio signature validation (dev/seed only — NEVER in production).
SKIP_SIGNATURE_VALIDATION=false

# AWS S3 — optional. Set AWS_S3_BUCKET to enable automatic recording uploads to S3.
# Leave these blank to keep recordings served directly from Twilio.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
